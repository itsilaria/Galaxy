'use client';

export default function Error({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  return (
    <div className="fixed inset-0 bg-black text-white p-8 overflow-auto">
      <h2 className="text-2xl mb-4">Errore Mobile Debug:</h2>
      <pre className="text-xs bg-red-900/20 p-4 rounded overflow-auto">
        {error.message}
        {'\n\n'}
        {error.stack}
      </pre>
      <button 
        onClick={reset}
        className="mt-4 bg-white text-black px-4 py-2 rounded"
      >
        Riprova
      </button>
    </div>
  );
}
